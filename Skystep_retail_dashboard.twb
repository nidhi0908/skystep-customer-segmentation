    <worksheet name='4 - Customer Lifecycle'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Book' fontsize='10'>Customer Distribution Across Lifecycle Stages</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Book' fontsize='8' italic='true'>Identifying the Danger Zone Where Customers Slip Away</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='SkyStep_Final_Tableau_Data' name='federated.0la51cs1qaio92113v6p31ub2jut' />
