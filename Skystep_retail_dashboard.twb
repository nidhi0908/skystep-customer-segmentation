            </column>
            <column caption='Recency Bucket' datatype='string' name='[Calculation_1158832523529334786]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [recency] &lt;= 30 THEN &quot;1. Active (0-30 days)&quot;&#13;&#10;   ELSEIF [recency] &lt;= 60 THEN &quot;2. Engaged (31-60 days)&quot;&#13;&#10;   ELSEIF [recency] &lt;= 90 THEN &quot;3. Cooling (61-90 days)&quot;&#13;&#10;   ELSEIF [recency] &lt;= 120 THEN &quot;4. At Risk (91-120 days)&quot;&#13;&#10;   ELSEIF [recency] &lt;= 180 THEN &quot;5. Slipping (121-180 days)&quot;&#13;&#10;   ELSE &quot;6. Dormant (180+ days)&quot;&#13;&#10;   END' />
            </column>
